  "architecture": {
    "64bit": {
      "url": "https://github.com/t09tanaka/nectar/releases/download/v{{VERSION}}/nectar-windows-x64.exe",
      "hash": "{{WINDOWS_X64_SHA256}}",
      "bin": [
        [
