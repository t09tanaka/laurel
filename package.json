{
  "name": "nectar",
  "version": "0.1.0",
  "description": "Ghost-theme-compatible static site generator powered by Markdown and Bun",
  "license": "MIT",
  "author": "Takuto Tanaka <t09tanaka@gmail.com>",
  "homepage": "https://github.com/t09tanaka/nectar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t09tanaka/nectar.git"
  },
  "bugs": {
    "url": "https://github.com/t09tanaka/nectar/issues"
  },
  "keywords": [
    "ghost",
    "ghost-theme",
    "static-site-generator",
    "ssg",
    "handlebars",
    "markdown",
    "bun",
    "blog"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "nectar": "./dist/cli.mjs"
  },
  "types": "./dist/types/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/build/index.d.ts",
      "default": "./dist/build.mjs"
    },
    "./build": {
      "types": "./dist/types/build/index.d.ts",
      "default": "./dist/build.mjs"
    },
    "./cli": {
      "types": "./dist/types/cli/index.d.ts",
      "default": "./dist/cli.mjs"
    },
    "./types": {
      "types": "./dist/types/types.d.ts",
      "default": "./dist/types.mjs"
    },
    "./plugin": {
      "types": "./dist/types/plugin/index.d.ts",
      "default": "./dist/plugin.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist/dashboard-bundle",
    "README.md",
    "TELEMETRY.md",
    "LICENSE",
    "CHANGELOG.md",
    "VERSIONING.md"
  ],
  "scripts": {
    "build": "bun run src/cli/index.ts build",
    "build:example": "cd example && bun ../src/cli/index.ts build",
    "build:docs-site": "cd docs-site && bun ../src/cli/index.ts build",
    "build:cli": "bun run scripts/build-cli.ts",
    "build:dashboard-bundle": "bun run scripts/build-dashboard-bundle.ts",
    "build:skill-bundle": "bun run scripts/build-skill-bundle.ts",
    "build:types": "tsc -p tsconfig.types.json",
    "compile": "bun run scripts/compile.ts",
    "compile:all": "bun run scripts/compile.ts --all",
    "build:binary": "bun run scripts/compile.ts",
    "build:binary:all": "bun run scripts/compile.ts --all",
    "build:binary:shasums": "bun run scripts/compile.ts --all --shasums",
    "homebrew:formula": "bun run scripts/generate-homebrew-formula.ts",
    "scoop:manifest": "bun run scripts/generate-scoop-manifest.ts",
    "sbom:cyclonedx": "mkdir -p dist-sbom && cdxgen -t js --no-install-deps --json-pretty --output dist-sbom/nectar.cyclonedx.json .",
    "docs:cli": "bun run src/cli/docs.ts",
    "docs:config": "bun run src/config/docs.ts",
    "docs:theme-reference": "bun run scripts/docs-theme-reference.ts",
    "prepublishOnly": "bun run build:dashboard-bundle && bun run build:skill-bundle && bun run build:cli && bun run build:types",
    "test": "bun test --parallel",
    "test:serial": "bun test",
    "test:e2e": "bun test tests/e2e",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:coverage:gate": "bun test --coverage && bun scripts/coverage-gate.ts",
    "bench:performance": "bun tests/bench/performance.bench.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/cli/dashboard/web/tsconfig.json",
    "check": "biome check src tests",
    "format": "biome format --write src tests",
    "lint": "biome lint src tests",
    "lint:html": "html-validate \"example/dist/**/*.html\"",
    "size:theme-bundle": "bun scripts/theme-bundle-size.ts",
    "size:pages": "bun scripts/page-weight-gate.ts",
    "verify:lockfile": "bun install --frozen-lockfile",
    "verify:bun-path-alias": "bun scripts/verify-bun-path-alias.ts",
    "security:pm-scan": "bun scripts/bun-pm-scan.ts",
    "lint:a11y": "bun run scripts/a11y-gate.ts",
    "lint:lighthouse": "bun run scripts/lighthouse-gate.ts",
    "qa:dashboard-visual": "bun scripts/dashboard-visual-qa.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@iarna/toml": "^2.2.5",
    "dayjs": "^1.11.13",
    "dom-serializer": "2.0.0",
    "domhandler": "5.0.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "htmlparser2": "10.1.0",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.2",
    "markdown-it-cjk-friendly": "^2.0.2",
    "marked": "14.1.4",
    "marked-gfm-heading-id": "^4.1.1",
    "postcss": "^8.5.15",
    "postcss-prefix-selector": "^2.1.1",
    "preact": "^10.29.2",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.7",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-view": "^1.41.8",
    "sanitize-html": "^2.17.4",
    "shiki": "^4.1.0",
    "slugify": "^1.6.6",
    "turndown": "^7.2.0",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "html-minifier-terser": "^7.2.0",
    "lunr": "^2.3.9",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@biomejs/biome": "^1.9.4",
    "@cyclonedx/cdxgen": "12.4.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tryghost/content-api": "^1.12.8",
    "@types/bun": "latest",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14",
    "@types/sanitize-html": "^2.16.1",
    "@types/turndown": "^5.0.5",
    "@types/xml2js": "^0.4.14",
    "chrome-launcher": "1.2.1",
    "bun-plugin-tailwind": "^0.1.2",
    "html-validate": "^9",
    "lighthouse": "^13.3.0",
    "pagefind": "^1.5.2",
    "puppeteer-core": "24.43.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "proxy-agent": "6.4.0",
    "tmp": "^0.2.6"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
