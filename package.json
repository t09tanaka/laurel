{
  "name": "nectar",
  "version": "0.1.0",
  "description": "Ghost-theme-compatible static site generator powered by Markdown and Bun",
  "license": "MIT",
  "author": "Takuto Tanaka <t09tanaka@gmail.com>",
  "homepage": "https://github.com/t09tanaka/nectar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t09tanaka/nectar.git"
  },
  "bugs": {
    "url": "https://github.com/t09tanaka/nectar/issues"
  },
  "keywords": [
    "ghost",
    "ghost-theme",
    "static-site-generator",
    "ssg",
    "handlebars",
    "markdown",
    "bun",
    "blog"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "nectar": "./dist/cli.mjs"
  },
  "types": "./dist/types/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/build/index.d.ts",
      "default": "./dist/build.mjs"
    },
    "./build": {
      "types": "./dist/types/build/index.d.ts",
      "default": "./dist/build.mjs"
    },
    "./cli": {
      "types": "./dist/types/cli/index.d.ts",
      "default": "./dist/cli.mjs"
    },
    "./types": {
      "types": "./dist/types/types.d.ts",
      "default": "./src/types.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun run src/cli/index.ts build",
    "build:example": "cd example && bun ../src/cli/index.ts build",
    "build:cli": "bun run scripts/build-cli.ts",
    "build:types": "tsc -p tsconfig.types.json",
    "compile": "bun run scripts/compile.ts",
    "compile:all": "bun run scripts/compile.ts --all",
    "prepublishOnly": "bun run build:cli && bun run build:types",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "check": "biome check src tests",
    "format": "biome format --write src tests",
    "lint": "biome lint src tests"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "dayjs": "^1.11.13",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "marked": "^14.1.4",
    "marked-gfm-heading-id": "^4.1.1",
    "sanitize-html": "^2.17.4",
    "slugify": "^1.6.6",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/sanitize-html": "^2.16.1",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
