<article class="gh-card kg-width-{{width}} {{post_class}}">
  {{#if feature_image}}
    <a class="gh-card-image" href="{{url}}">
      <img src="{{img_url feature_image size="m"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    </a>
  {{/if}}
  <div class="gh-card-content">
    <h3><a href="{{url}}">{{title}}</a></h3>
    {{#if excerpt}}<p>{{excerpt words="20"}}</p>{{/if}}
    <footer>
      {{#if primary_author}}<span>{{primary_author.name}}</span>{{/if}}
      <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
    </footer>
  </div>
</article>
