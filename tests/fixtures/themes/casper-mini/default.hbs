<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
  <meta charset="utf-8">
  <title>{{meta_title}}</title>
  {{ghost_head}}
  <link rel="stylesheet" href="{{asset "built/screen.css"}}">
</head>
<body class="{{body_class}}">
  <a class="nectar-skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <a href="{{@site.url}}">{{@site.title}}</a>
    {{!-- Casper-style header probes @member to swap Sign in / Account labels --}}
    {{#unless @member}}
      <button class="gh-signin" data-portal="signin">{{t "Sign in"}}</button>
    {{else}}
      <span class="gh-member-name">{{@member.name}}</span>
      {{#unless @member.paid}}
        <button class="gh-upgrade" data-portal="upgrade">{{t "Upgrade"}}</button>
      {{/unless}}
    {{/unless}}
  </header>
  <main id="main">
    {{{body}}}
  </main>
  <footer>{{t "Powered by %" "Casper-Mini"}}</footer>
  {{ghost_foot}}
</body>
</html>
