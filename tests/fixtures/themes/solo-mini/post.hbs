{{!< default}}
<article class="solo-post {{post_class}}">
  {{#if feature_image}}
    <header class="gh-canvas solo-image-header">
      <img src="{{img_url feature_image}}" alt="{{feature_image_alt}}">
      <h1>{{title}}</h1>
    </header>
  {{/if}}

  {{#unless feature_image}}
    <header class="gh-content gh-canvas solo-fallback-header">
      <h1>{{title}}</h1>
    </header>
  {{/unless}}

  <section class="gh-content gh-canvas">
    {{content}}
  </section>
</article>
