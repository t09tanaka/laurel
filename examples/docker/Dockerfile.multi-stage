# Multi-stage image for hosts that build the Nectar site during docker build.
# Copy this file and nginx.conf to your site root, then run:
#   docker build -t nectar-static .
FROM oven/bun AS build

WORKDIR /app
COPY . .
RUN bun install
RUN bunx nectar build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/ /usr/share/nginx/html/

EXPOSE 80

HEALTHCHECK CMD wget -q -O /dev/null http://localhost/healthz
