# Terraform fragment for an aws_cloudfront_distribution serving Nectar from S3.
#
# Copy these blocks into the distribution resource that uses your private S3
# origin. Private S3 REST origins can return either 403 or 404 for a missing
# key, depending on bucket permissions, so map both errors to Nectar's generated
# /404.html page while preserving a 404 viewer response.

custom_error_response {
  error_code            = 403
  response_code         = 404
  response_page_path    = "/404.html"
  error_caching_min_ttl = 60
}

custom_error_response {
  error_code            = 404
  response_code         = 404
  response_page_path    = "/404.html"
  error_caching_min_ttl = 60
}
