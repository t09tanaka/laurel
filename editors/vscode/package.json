{
  "name": "vscode-laurel",
  "displayName": "Laurel",
  "description": "VS Code language support and tasks for Laurel sites.",
  "version": "0.1.0",
  "publisher": "laurel",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Snippets", "Other"],
  "keywords": ["laurel", "ghost", "static-site-generator", "toml", "markdown"],
  "repository": {
    "type": "git",
    "url": "https://github.com/t09tanaka/laurel.git",
    "directory": "editors/vscode"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:laurel-config",
    "onTaskType:laurel",
    "onCommand:workbench.action.tasks.runTask",
    "workspaceContains:laurel.toml",
    "workspaceContains:laurel.config.toml"
  ],
  "extensionKind": ["workspace"],
  "contributes": {
    "languages": [
      {
        "id": "laurel-config",
        "aliases": ["Laurel Config", "laurel.config.toml"],
        "filenames": ["laurel.config.toml", "laurel.toml"],
        "configuration": "./language-configuration/laurel-config.json"
      }
    ],
    "grammars": [
      {
        "language": "laurel-config",
        "scopeName": "source.laurel-config",
        "path": "./grammars/laurel-config.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/frontmatter.code-snippets"
      }
    ],
    "problemMatchers": [
      {
        "name": "laurel",
        "owner": "laurel",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^----\\s+(.+?)(?::(\\d+)(?::(\\d+))?)?\\s+-\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "laurel",
        "required": ["task"],
        "properties": {
          "task": {
            "type": "string",
            "description": "Laurel task to run.",
            "enum": ["build", "dev", "check"]
          }
        }
      }
    ]
  }
}
